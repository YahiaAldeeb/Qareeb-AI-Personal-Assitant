<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base theme -->
    <style name="Base.Theme.Qareeb" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- your theme items here -->
    </style>

    <!-- Main app theme -->
    <style name="Theme.Qareeb" parent="Base.Theme.Qareeb" />

    <!-- Splash theme -->
    <style name="Theme.Qareeb.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#6B46C1</item>
<!--        <item name="windowSplashScreenAnimatedIcon">@drawable/qareeb</item>-->
        <item name="postSplashScreenTheme">@style/Theme.Qareeb</item>
    </style>

    <style name="Theme.Qareeb.Translucent" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>

</resources>